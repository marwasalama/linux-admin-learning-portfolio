$TTL 86400
@   IN  SOA masterdns.lab.local. root.lab.local. (
        2026061001 ; Serial
        3600       ; Refresh
        1800       ; Retry
        604800     ; Expire
        86400      ; Minimum TTL
)

@       IN  NS      masterdns.lab.local.
135     IN  PTR     masterdns.lab.local.
136     IN  PTR     clienta.lab.local.
137     IN  PTR     clientb.lab.local.
